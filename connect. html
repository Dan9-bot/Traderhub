<!DOCTYPE html>
<html>
<head>
    <title>Connect Deriv</title>
</head>
<body>

<h2>Connecting to Deriv...</h2>

<script>
const APP_ID = "33Pp6Q49Gvdxxyne3T2Ks";
const REDIRECT_URI = "https://traderhub-xi.vercel.app/connect.html";

const params = new URLSearchParams(window.location.search);
const token = params.get("token1");

if (token) {
    localStorage.setItem("deriv_token", token);
    window.location.href = "trader.html";
} else {
    window.location.href =
        `https://oauth.deriv.com/oauth2/authorize?app_id=${APP_ID}&redirect_uri=${encodeURIComponent(REDIRECT_URI)}`;
}
</script>

</body>
</html>
